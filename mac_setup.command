#!/bin/bash
# ============================================================
#  BudgetPal – Mac Setup
#  Double-click this once. After that, use the Desktop icon.
# ============================================================

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
DESKTOP="$HOME/Desktop"
APPLET_DIR="$DESKTOP/🐷 BudgetPal.app"

echo ""
echo "🐷 BudgetPal Mac Setup"
echo "========================"
echo ""

# ── 1. Find a working Python 3.9+ ────────────────────────────
# macOS Sequoia ships a broken stub python3. We need a real one.
# Check known install locations in order of preference.

PYTHON=""
for candidate in \
    "/usr/local/bin/python3.13" \
    "/usr/local/bin/python3.12" \
    "/usr/local/bin/python3.11" \
    "/usr/local/bin/python3.10" \
    "/usr/local/bin/python3.9" \
    "/opt/homebrew/bin/python3" \
    "/opt/homebrew/bin/python3.13" \
    "/opt/homebrew/bin/python3.12" \
    "$HOME/Library/Python/3.*/bin/python3" \
    "/Library/Frameworks/Python.framework/Versions/3.*/bin/python3"
do
    # Expand globs
    for expanded in $candidate; do
        if [ -f "$expanded" ]; then
            # Make sure it actually runs (not a broken stub)
            VERSION=$("$expanded" -c "import sys; print(sys.version_info[:2])" 2>/dev/null)
            if [ $? -eq 0 ]; then
                PYTHON="$expanded"
                break 2
            fi
        fi
    done
done

if [ -z "$PYTHON" ]; then
    echo "→ Python 3 not found. Downloading installer..."
    echo ""

    # Detect Apple Silicon vs Intel
    ARCH=$(uname -m)
    if [ "$ARCH" = "arm64" ]; then
        PY_URL="https://www.python.org/ftp/python/3.13.3/python-3.13.3-macos11.pkg"
    else
        PY_URL="https://www.python.org/ftp/python/3.13.3/python-3.13.3-macos11.pkg"
    fi

    PKG="/tmp/python3_installer.pkg"
    echo "→ Downloading Python 3.13.3 (this may take a minute)..."
    curl -L --progress-bar "$PY_URL" -o "$PKG"

    echo "→ Installing Python 3.13.3..."
    echo "   (macOS may ask for your password — this is normal)"
    sudo installer -pkg "$PKG" -target /
    rm -f "$PKG"

    # Now find it
    for candidate in \
        "/usr/local/bin/python3.13" \
        "/usr/local/bin/python3" \
        "/Library/Frameworks/Python.framework/Versions/3.13/bin/python3"
    do
        if [ -f "$candidate" ]; then
            VERSION=$("$candidate" -c "import sys; print(sys.version_info[:2])" 2>/dev/null)
            if [ $? -eq 0 ]; then
                PYTHON="$candidate"
                break
            fi
        fi
    done

    if [ -z "$PYTHON" ]; then
        echo ""
        echo "❌ Python installation failed."
        echo "   Please go to https://www.python.org/downloads/"
        echo "   Download and install Python 3.13, then run this script again."
        echo ""
        read -p "Press Enter to close..."
        exit 1
    fi
fi

echo "✓ Python found: $PYTHON"
echo "  Version: $($PYTHON --version 2>&1)"
echo ""

# ── 2. Install pip if missing ─────────────────────────────────
if ! "$PYTHON" -m pip --version &>/dev/null 2>&1; then
    echo "→ Installing pip..."
    "$PYTHON" -m ensurepip --upgrade 2>/dev/null || \
        curl -s https://bootstrap.pypa.io/get-pip.py | "$PYTHON"
fi

# ── 3. Install dependencies ───────────────────────────────────
echo "→ Installing openpyxl..."
"$PYTHON" -m pip install --quiet --upgrade openpyxl

echo "→ Installing pillow..."
"$PYTHON" -m pip install --quiet --upgrade pillow
# Verify ImageTk is available (requires tkinter support in Pillow)
"$PYTHON" -c "from PIL import ImageTk" 2>/dev/null || {
    echo "→ Reinstalling pillow with full support..."
    "$PYTHON" -m pip install --quiet --force-reinstall pillow
}

echo "→ Installing numpy..."
"$PYTHON" -m pip install --quiet --upgrade numpy

echo "✓ Dependencies installed."
echo ""

# ── 4. Copy app files to local Mac storage ───────────────────
LOCAL_DIR="$HOME/Documents/BudgetPal"
echo "→ Copying app files to $LOCAL_DIR..."
mkdir -p "$LOCAL_DIR/user_data"
cp "$SCRIPT_DIR/app.py"          "$LOCAL_DIR/app.py"
cp "$SCRIPT_DIR/data_manager.py" "$LOCAL_DIR/data_manager.py"
[ -f "$SCRIPT_DIR/version.txt" ] && cp "$SCRIPT_DIR/version.txt" "$LOCAL_DIR/version.txt"
# Copy any existing user data
if [ -d "$SCRIPT_DIR/user_data" ]; then
    cp -n "$SCRIPT_DIR/user_data/"*.xlsx "$LOCAL_DIR/user_data/" 2>/dev/null || true
fi
echo "✓ App files copied."
echo ""

# ── 5. Create the .app bundle on Desktop ─────────────────────
APPLET_MACOS="$APPLET_DIR/Contents/MacOS"
APPLET_RES="$APPLET_DIR/Contents/Resources"

# Remove old version if exists
rm -rf "$APPLET_DIR"
mkdir -p "$APPLET_MACOS" "$APPLET_RES"

# The launcher executable — references local copy, not the shared folder
cat > "$APPLET_MACOS/BudgetPal" << APPLET_EOF
#!/bin/bash
export PATH="/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin:$PATH"
mkdir -p "$HOME/Library/Logs"
echo "--- Launch $(date) ---" >> "$HOME/Library/Logs/BudgetPal.log"
exec "$PYTHON" "$HOME/Documents/BudgetPal/app.py" 2>>"$HOME/Library/Logs/BudgetPal.log"
APPLET_EOF
chmod +x "$APPLET_MACOS/BudgetPal"

# Info.plist
cat > "$APPLET_DIR/Contents/Info.plist" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>    <string>BudgetPal</string>
    <key>CFBundleIdentifier</key>   <string>com.budgetpal.app</string>
    <key>CFBundleName</key>         <string>BudgetPal</string>
    <key>CFBundleIconFile</key>     <string>AppIcon</string>
    <key>CFBundlePackageType</key>  <string>APPL</string>
    <key>CFBundleVersion</key>      <string>1.0</string>
    <key>CFBundleShortVersionString</key> <string>1.0</string>
    <key>LSMinimumSystemVersion</key>    <string>10.13</string>
    <key>NSHighResolutionCapable</key>   <true/>
</dict>
</plist>
PLIST_EOF

# ── 5. Generate icon from embedded piggy bank sprite ─────────
"$PYTHON" - << ICON_EOF
import os, sys, base64

# Decode embedded icon
B64 = """"""

png_path = "/tmp/budgetpal_piggy.png"
with open(png_path, "wb") as f:
    f.write(base64.b64decode(B64))

try:
    from PIL import Image
    src = Image.open(png_path).convert("RGBA")
    iconset = "/tmp/BudgetPal.iconset"
    os.makedirs(iconset, exist_ok=True)
    for sz in [16, 32, 64, 128, 256, 512, 1024]:
        src.resize((sz, sz), Image.LANCZOS).save(f"{iconset}/icon_{sz}x{sz}.png")
        src.resize((sz*2, sz*2), Image.LANCZOS).save(f"{iconset}/icon_{sz}x{sz}@2x.png")
    icns = "$APPLET_RES/AppIcon.icns"
    os.system(f"iconutil -c icns '{iconset}' -o '{icns}' 2>/dev/null || true")
    print("Icon built from piggy bank sprite.")
except Exception as e:
    print(f"Icon generation skipped: {e}")
ICON_EOF

# ── 6. Clear quarantine on everything ────────────────────────
xattr -cr "$APPLET_DIR" 2>/dev/null || true
xattr -cr "$SCRIPT_DIR" 2>/dev/null || true

# ── 7. Register with Launch Services so Finder shows icon ────
/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister \
    -f "$APPLET_DIR" 2>/dev/null || true

echo "✅ Done!"
echo ""
echo "   A 🐷 BudgetPal icon is now on your Desktop."
echo "   Double-click it anytime to open BudgetPal."
echo "   You never need to open Terminal again."
echo ""
read -p "Press Enter to close this window..."
